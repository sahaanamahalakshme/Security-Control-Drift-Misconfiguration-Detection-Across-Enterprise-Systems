# SentinelDNA — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to Git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini (Primary LLM) ──────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Used in: backend/config/llm_config.py  →  get_gemini_client() / call_gemini()
GEMINI_API_KEY=your_gemini_api_key_here

# ── HuggingFace (Fallback LLM) ───────────────────────────────────────────────
# Get your token from: https://huggingface.co/settings/tokens
# Used in: backend/config/llm_config.py  →  call_huggingface()
# Model used: mistralai/Mistral-7B-Instruct-v0.3
HF_API_TOKEN=your_huggingface_token_here

# ── Slack Webhook (Optional — Alerting) ──────────────────────────────────────
# Get from: https://api.slack.com/apps → Incoming Webhooks
# Used in: backend/remediation/webhook_dispatcher.py
# Leave blank to run in MOCK mode (console output only, zero config needed)
SLACK_WEBHOOK_URL=
